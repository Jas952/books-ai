{
  "name": "books-agent",
  "private": true,
  "version": "0.1.8",
  "type": "module",
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.dmitriy.booksagent",
    "productName": "Books Agent",
    "publish": [
      {
        "provider": "github",
        "owner": "Jas952",
        "repo": "books-ai"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/image.icns",
      "artifactName": "installers/${productName}-${version}.${ext}"
    },
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "books",
        "to": "books",
        "filter": [
          "**/*.pdf"
        ]
      },
      {
        "from": "ai-server",
        "to": "ai-server"
      },
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ]
  },
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build:vite": "vite build",
    "build:mac": "npm run build:vite && electron-builder --mac",
    "release": "npm run build:vite && node scripts/run-release.cjs",
    "version:patch": "npm version patch --no-git-tag-version --force && npm run build:mac",
    "version:minor": "npm version minor --no-git-tag-version --force && npm run build:mac",
    "version:major": "npm version major --no-git-tag-version --force && npm run build:mac",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron-updater": "^6.6.2",
    "lucide-react": "^1.14.0",
    "pdfjs-dist": "4.4.168",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-pdf-highlighter": "^8.0.0-rc.0",
    "react-resizable-panels": "^4.11.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.11.0",
    "vite": "^5.4.10",
    "wait-on": "^9.0.5"
  }
}
